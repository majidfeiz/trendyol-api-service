# Server
PORT=8080

# Trendyol
TRENDYOL_BASE_URL=https://public.trendyol.com

# Request Settings
REQUEST_TIMEOUT_SECONDS=15
MAX_CONCURRENT=20
RETRY_COUNT=3

# Cache (in-memory, TTL in seconds)
CACHE_ENABLED=true
CACHE_TTL_SECONDS=120

# Batch limit
MAX_BATCH_SIZE=50

# Proxy (اختیاری — اگه public.trendyol.com از شبکه شما در دسترس نیست)
# HTTPS_PROXY=http://your-proxy-host:port
# HTTP_PROXY=http://your-proxy-host:port
